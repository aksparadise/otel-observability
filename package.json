{
    "name": "@aksparadise/otel-observability",
    "version": "1.0.4",
    "description": "Production-ready OpenTelemetry plugin for SigNoz and Grafana observability with zero-configuration setup. Supports Express, GraphQL, Next.js, and more.",
    "main": "src/index.js",
    "type": "module",
    "exports": {
        ".": {
            "import": "./src/index.js",
            "types": "./src/index.d.ts"
        },
        "./otel": {
            "import": "./src/otel.js",
            "types": "./src/otel.d.ts"
        },
        "./tracer": {
            "import": "./src/tracer.js",
            "types": "./src/tracer.d.ts"
        },
        "./metrics": {
            "import": "./src/metrics.js",
            "types": "./src/metrics.d.ts"
        },
        "./logger": {
            "import": "./src/logger.js",
            "types": "./src/logger.d.ts"
        },
        "./middleware": {
            "import": "./src/middleware.js",
            "types": "./src/middleware.d.ts"
        },
        "./sanitizer": {
            "import": "./src/sanitizer.js",
            "types": "./src/sanitizer.d.ts"
        },
        "./error-handler": {
            "import": "./src/errorHandler.js",
            "types": "./src/errorHandler.d.ts"
        },
        "./security": {
            "import": "./src/security.js",
            "types": "./src/security.d.ts"
        }
    },
    "scripts": {
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "security-check": "node src/security.js",
        "update-deps": "npm update"
    },
    "keywords": [
        "opentelemetry",
        "otel",
        "signoz",
        "grafana",
        "observability",
        "tracing",
        "metrics",
        "logging",
        "monitoring",
        "apm",
        "graphql",
        "nextjs",
        "express",
        "security"
    ],
    "author": "AksParadise",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aksparadise/otel-observability.git"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@aksparadise/otel-observability": "^1.0.1",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/api-logs": "^0.214.0",
        "@opentelemetry/auto-instrumentations-node": "^0.72.0",
        "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
        "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
        "@opentelemetry/instrumentation-graphql": "^0.44.0",
        "@opentelemetry/resources": "^2.6.1",
        "@opentelemetry/sdk-logs": "^0.214.0",
        "@opentelemetry/sdk-metrics": "^2.6.1",
        "@opentelemetry/sdk-node": "^0.214.0",
        "@opentelemetry/sdk-trace-base": "^2.6.1",
        "@opentelemetry/semantic-conventions": "^1.40.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.1",
        "@vitest/coverage-v8": "^4.1.5",
        "dotenv": "^16.4.0",
        "eslint": "^9.30.1",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "@apollo/server": ">=4.0.0",
        "express": ">=4.18.0",
        "graphql": ">=16.0.0",
        "next": ">=13.0.0"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        },
        "graphql": {
            "optional": true
        },
        "@apollo/server": {
            "optional": true
        },
        "next": {
            "optional": true
        }
    }
}
