{
    "name": "@aksparadise/otel-observability",
    "version": "1.1.25",
    "description": "Production-ready OpenTelemetry plugin for SigNoz and Grafana observability. Minimal setup for Node.js, Express, NestJS, Next.js. Automatic instrumentation, distributed tracing, metrics, and logging. Created by AksParadise.",
    "type": "module",
    "main": "./dist/cjs/index.cjs",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/index.d.ts",
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/aksparadise/otel-observability.git"
    },
    "bugs": {
        "url": "https://github.com/aksparadise/otel-observability/issues"
    },
    "homepage": "https://github.com/aksparadise/otel-observability#readme",
    "keywords": [
        "opentelemetry",
        "observability",
        "tracing",
        "metrics",
        "logging",
        "signoz",
        "grafana",
        "otel",
        "monitoring",
        "apm",
        "nestjs",
        "express",
        "nextjs",
        "aksparadise"
    ],
    "files": [
        "dist/",
        "README.md",
        "QUICKSTART.md",
        "examples/",
        "package.json"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.mjs",
            "require": "./dist/cjs/index.cjs"
        },
        "./otel": {
            "types": "./dist/otel.d.ts",
            "import": "./dist/esm/otel.mjs",
            "require": "./dist/cjs/otel.cjs"
        },
        "./tracer": {
            "types": "./dist/tracer.d.ts",
            "import": "./dist/esm/tracer.mjs",
            "require": "./dist/cjs/tracer.cjs"
        },
        "./metrics": {
            "types": "./dist/metrics.d.ts",
            "import": "./dist/esm/metrics.mjs",
            "require": "./dist/cjs/metrics.cjs"
        },
        "./logger": {
            "types": "./dist/logger.d.ts",
            "import": "./dist/esm/logger.mjs",
            "require": "./dist/cjs/logger.cjs"
        },
        "./middleware": {
            "types": "./dist/middleware.d.ts",
            "import": "./dist/esm/middleware.mjs",
            "require": "./dist/cjs/middleware.cjs"
        },
        "./sanitizer": {
            "types": "./dist/sanitizer.d.ts",
            "import": "./dist/esm/sanitizer.mjs",
            "require": "./dist/cjs/sanitizer.cjs"
        },
        "./error-handler": {
            "types": "./dist/error-handler.d.ts",
            "import": "./dist/esm/errorHandler.mjs",
            "require": "./dist/cjs/errorHandler.cjs"
        },
        "./security": {
            "types": "./dist/security.d.ts",
            "import": "./dist/esm/security.mjs",
            "require": "./dist/cjs/security.cjs"
        },
        "./nestjs-logger": {
            "types": "./dist/nestjs-logger.d.ts",
            "import": "./dist/esm/nestjs-logger.mjs",
            "require": "./dist/cjs/nestjs-logger.cjs"
        },
        "./setup": {
            "types": "./dist/setup.d.ts",
            "import": "./dist/esm/setup.mjs",
            "require": "./dist/cjs/setup.cjs"
        },
        "./context": {
            "types": "./dist/context.d.ts",
            "import": "./dist/esm/context.mjs",
            "require": "./dist/cjs/context.cjs"
        }
    },
    "typesVersions": {
        "*": {
            "otel": [
                "dist/otel.d.ts"
            ],
            "tracer": [
                "dist/tracer.d.ts"
            ],
            "metrics": [
                "dist/metrics.d.ts"
            ],
            "logger": [
                "dist/logger.d.ts"
            ],
            "middleware": [
                "dist/middleware.d.ts"
            ],
            "sanitizer": [
                "dist/sanitizer.d.ts"
            ],
            "error-handler": [
                "dist/error-handler.d.ts"
            ],
            "security": [
                "dist/security.d.ts"
            ],
            "nestjs-logger": [
                "dist/nestjs-logger.d.ts"
            ],
            "setup": [
                "dist/setup.d.ts"
            ],
            "context": [
                "dist/context.d.ts"
            ],
            "*": [
                "dist/index.d.ts"
            ]
        }
    },
    "scripts": {
        "build": "npm run build:esm && npm run build:cjs && npm run build:types",
        "build:esm": "node build-esm.js",
        "build:cjs": "node build-cjs.js",
        "build:types": "node build-types.js",
        "prepublishOnly": "npm run build",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "security-check": "node src/security.js",
        "update-deps": "npm update"
    },
    "author": "AksParadise",
    "license": "MIT",
    "dependencies": {
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/api-logs": "^0.218.0",
        "@opentelemetry/auto-instrumentations-node": "^0.76.0",
        "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
        "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
        "@opentelemetry/instrumentation-graphql": "^0.66.0",
        "@opentelemetry/resources": "^2.7.1",
        "@opentelemetry/sdk-logs": "^0.218.0",
        "@opentelemetry/sdk-metrics": "^2.7.1",
        "@opentelemetry/sdk-node": "^0.218.0",
        "@opentelemetry/sdk-trace-base": "^2.7.1",
        "@opentelemetry/semantic-conventions": "^1.40.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.1",
        "@vitest/coverage-v8": "^4.1.5",
        "dotenv": "^16.4.0",
        "esbuild": "^0.28.0",
        "eslint": "^9.30.1",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "@apollo/server": ">=4.0.0",
        "express": ">=4.18.0",
        "graphql": ">=16.0.0",
        "next": ">=13.0.0"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        },
        "graphql": {
            "optional": true
        },
        "@apollo/server": {
            "optional": true
        },
        "next": {
            "optional": true
        }
    }
}
