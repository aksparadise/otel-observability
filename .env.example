# ====================================
# @aksparadise/otel-observability Environment Variables
# ====================================
# This file contains all environment variables used by @aksparadise/otel-observability
# Copy this file to .env and update with your actual values
# ====================================

# ====================================
# Core OTel Configuration
# ====================================

# Enable or disable OpenTelemetry telemetry collection
# Set to 'true' to enable, 'false' to disable
# When disabled, all OTel operations become no-ops (no performance impact)
# Default: false
OTEL_ENABLED=false

# Backend selection - choose between SigNoz, Grafana, or custom
# Options: 'signoz' (default), 'grafana', 'custom'
# Default: signoz
OTEL_BACKEND=signoz

# Service name - appears in observability UI and all telemetry data
# Use a descriptive name that identifies your service
# Examples: 'api-gateway', 'user-service', 'payment-processor'
# Default: unknown-service
OTEL_SERVICE_NAME=my-service

# Service version - useful for tracking deployments
# Recommended to use your package.json version or git commit
# Examples: '1.0.0', '2.3.1', 'abc123def'
# Default: 1.0.0
OTEL_SERVICE_VERSION=1.0.0

# ====================================
# SigNoz Configuration (when OTEL_BACKEND=signoz)
# ====================================

# OTel Collector endpoint - where telemetry data is sent
# This should point to your SigNoz OTel collector
# Default: http://localhost:4318
# Examples:
#   - Local SigNoz: http://localhost:4318
#   - Remote SigNoz: http://signoz.example.com:4318
#   - Docker Compose: http://otel-collector:4318
#   - Kubernetes: http://signoz-otel-collector.signoz:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ====================================
# Grafana Cloud Configuration (when OTEL_BACKEND=grafana)
# ====================================

# Grafana Cloud OTel endpoint
# Get this from your Grafana Cloud instance
# Default: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# Examples:
#   - Grafana Cloud US: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
#   - Grafana Cloud EU: https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
#   - Self-hosted Grafana: http://your-grafana:4318
GRAFANA_OTEL_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# Grafana Cloud API Key
# Get this from Grafana Cloud > Your Stack > API Keys
# Required when using Grafana backend
# Default: (empty)
GRAFANA_API_KEY=

# Grafana Instance ID (optional)
# Your Grafana Cloud instance identifier
# Default: (empty)
GRAFANA_INSTANCE_ID=

# ====================================
# Custom Backend Configuration (when OTEL_BACKEND=custom)
# ====================================

# For custom backends, use OTEL_EXPORTER_OTLP_ENDPOINT
# The plugin will send OTLP data to this endpoint
# Make sure your custom backend supports OTLP protocol

# Trace sampling ratio - controls what percentage of traces are collected
# Value between 0.0 (0%) and 1.0 (100%)
# Recommended values:
#   - Development: 1.0 (sample all traces)
#   - Staging: 0.5 (sample 50% of traces)
#   - Production: 0.1 (sample 10% of traces)
#   - High-traffic production: 0.01 (sample 1% of traces)
# Default: 1.0
OTEL_TRACE_SAMPLING_RATIO=1.0

# Deployment environment - helps filter data in observability UI
# Common values: development, staging, production
# Default: development (or NODE_ENV if set)
OTEL_ENVIRONMENT=development

# Hostname - identifies the server instance
# Useful for multi-instance deployments
# Default: unknown (or HOSTNAME if set)
# Examples:
#   - Docker: Set automatically by container
#   - Kubernetes: Set automatically by pod
#   - Manual: server-1, api-server-prod-01
HOSTNAME=

# Framework detection - helps with framework-specific instrumentation
# Options: 'express', 'graphql', 'nextjs', 'custom'
# Default: express
OTEL_FRAMEWORK=express

# ====================================
# Advanced Configuration
# ====================================

# Metric export interval in milliseconds
# Controls how often metrics are sent to the collector
# Lower values = more real-time but higher network overhead
# Recommended: 30000 (30 seconds) for production
# Default: 30000
# Examples:
#   - Development: 10000 (10 seconds) for faster feedback
#   - Production: 60000 (60 seconds) to reduce overhead
OTEL_METRIC_EXPORT_INTERVAL=30000

# ====================================
# Environment-Specific Examples
# ====================================

# --- Development with SigNoz ---
# OTEL_ENABLED=true
# OTEL_BACKEND=signoz
# OTEL_SERVICE_NAME=my-service-dev
# OTEL_SERVICE_VERSION=1.0.0-dev
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACE_SAMPLING_RATIO=1.0
# OTEL_ENVIRONMENT=development

# --- Development with Grafana Cloud ---
# OTEL_ENABLED=true
# OTEL_BACKEND=grafana
# OTEL_SERVICE_NAME=my-service-dev
# OTEL_SERVICE_VERSION=1.0.0-dev
# GRAFANA_OTEL_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# GRAFANA_API_KEY=your-grafana-api-key
# OTEL_TRACE_SAMPLING_RATIO=1.0
# OTEL_ENVIRONMENT=development

# --- Staging with SigNoz ---
# OTEL_ENABLED=true
# OTEL_BACKEND=signoz
# OTEL_SERVICE_NAME=my-service-staging
# OTEL_SERVICE_VERSION=1.0.0-staging
# OTEL_EXPORTER_OTLP_ENDPOINT=http://staging-signoz.example.com:4318
# OTEL_TRACE_SAMPLING_RATIO=0.5
# OTEL_ENVIRONMENT=staging

# --- Production with Grafana Cloud ---
# OTEL_ENABLED=true
# OTEL_BACKEND=grafana
# OTEL_SERVICE_NAME=my-service-prod
# OTEL_SERVICE_VERSION=1.0.0
# GRAFANA_OTEL_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# GRAFANA_API_KEY=your-grafana-api-key
# OTEL_TRACE_SAMPLING_RATIO=0.1
# OTEL_ENVIRONMENT=production
# HOSTNAME=api-server-prod-01

# ====================================
# Docker Compose Example
# ====================================
# If using Docker Compose with SigNoz, use service names:
# OTEL_BACKEND=signoz
# OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4318

# If using Docker Compose with Grafana:
# OTEL_BACKEND=grafana
# GRAFANA_OTEL_ENDPOINT=http://grafana:4318

# ====================================
# Kubernetes Example
# ====================================
# If using Kubernetes with SigNoz, use service names:
# OTEL_BACKEND=signoz
# OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector.signoz:4318
# HOSTNAME can be set via pod metadata automatically

# If using Kubernetes with Grafana:
# OTEL_BACKEND=grafana
# GRAFANA_OTEL_ENDPOINT=http://grafana.grafana:4318
# GRAFANA_API_KEY can be set via Kubernetes secrets

# ====================================
# Security Notes
# ====================================
# - Never commit .env file to version control
# - Use different values for each environment
# - Rotate secrets regularly (especially GRAFANA_API_KEY)
# - Use environment-specific collector endpoints
# - Consider using secret management systems in production
# - For Grafana Cloud, use restricted API keys with minimal permissions

# ====================================
# Troubleshooting
# ====================================
# If telemetry data is not appearing:

# For SigNoz:
# 1. Verify OTEL_ENABLED=true and OTEL_BACKEND=signoz
# 2. Check OTEL_EXPORTER_OTLP_ENDPOINT is correct
# 3. Ensure SigNoz collector is running: docker ps | grep signoz
# 4. Check network connectivity to collector
# 5. Verify no firewall is blocking port 4318
# 6. Check application logs for OTel initialization messages

# For Grafana Cloud:
# 1. Verify OTEL_ENABLED=true and OTEL_BACKEND=grafana
# 2. Check GRAFANA_OTEL_ENDPOINT is correct for your region
# 3. Verify GRAFANA_API_KEY is valid and not expired
# 4. Check Grafana Cloud status page for outages
# 5. Verify API key has appropriate permissions
# 6. Check application logs for authentication errors

# General:
# 1. Check service name appears in observability UI
# 2. Verify sampling ratio is not too low (try 1.0 for testing)
# 3. Check browser console for network errors
# 4. Run npm run security-check to verify dependencies

# ====================================
# Performance Considerations
# ====================================
# - Higher sampling ratios = more data = more storage/network usage
# - Lower metric export intervals = more real-time but higher overhead
# - In high-traffic scenarios, use lower sampling ratios
# - Monitor storage usage and adjust accordingly
# - Grafana Cloud has usage limits, monitor your quota
# - SigNoz self-hosted: monitor disk space and CPU usage

# ====================================
# Framework-Specific Notes
# ====================================
# Express: Set OTEL_FRAMEWORK=express (default)
# GraphQL: Set OTEL_FRAMEWORK=graphql for GraphQL operation tracing
# Next.js: Set OTEL_FRAMEWORK=nextjs for Next.js page and API tracing
# Custom: Set OTEL_FRAMEWORK=custom for manual instrumentation
